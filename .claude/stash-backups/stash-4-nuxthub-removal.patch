diff --git a/packages/lighthouse-worker/src/index.ts b/packages/lighthouse-worker/src/index.ts
new file mode 100644
index 0000000..707d36d
--- /dev/null
+++ b/packages/lighthouse-worker/src/index.ts
@@ -0,0 +1,69 @@
+import type { UnlighthouseRouteReport } from '@unlighthouse/core'
+import type { Flags } from 'lighthouse'
+import fs from 'node:fs'
+import { join } from 'node:path'
+import { parentPort } from 'node:worker_threads'
+import lighthouse from 'lighthouse/core/index.cjs'
+
+interface WorkerData {
+  routeReport: UnlighthouseRouteReport
+  port: number
+  lighthouseOptions: Flags
+  returnArtifacts?: boolean // If true, return artifacts instead of writing to disk
+}
+
+interface WorkerResult {
+  success: boolean
+  error?: string
+  artifacts?: {
+    json: string
+    html: string
+  }
+}
+
+async function runLighthouse(data: WorkerData): Promise<WorkerResult> {
+  const { routeReport, port, lighthouseOptions, returnArtifacts } = data
+
+  const flags: Flags = {
+    ...lighthouseOptions,
+    output: ['html', 'json'],
+    port,
+  }
+
+  try {
+    const runnerResult = await lighthouse(routeReport.route.url, flags)
+
+    if (returnArtifacts) {
+      return {
+        success: true,
+        artifacts: {
+          json: runnerResult.report[1],
+          html: runnerResult.report[0],
+        },
+      }
+    }
+    else {
+      fs.writeFileSync(join(routeReport.artifactPath, 'lighthouse.json'), runnerResult.report[1])
+      fs.writeFileSync(join(routeReport.artifactPath, 'lighthouse.html'), runnerResult.report[0])
+      return { success: true }
+    }
+  }
+  catch (error) {
+    console.error('Lighthouse worker error:', error)
+    return {
+      success: false,
+      error: error instanceof Error ? error.message : String(error),
+    }
+  }
+}
+
+if (parentPort) {
+  parentPort.on('message', async (data: WorkerData) => {
+    const result = await runLighthouse(data)
+    parentPort!.postMessage(result)
+  })
+}
+else {
+  console.error('This script must be run as a worker thread')
+  process.exit(1)
+}
