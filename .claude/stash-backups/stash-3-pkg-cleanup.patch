+++ b/packages/core/src/h3.service.ts
@@ -0,0 +1,270 @@
+import type { Peer } from 'crossws'
+import { extname, join } from 'node:path'
+import { plugin as wsPlugin } from 'crossws/server'
+import fs from 'fs-extra'
+import {
+  defineWebSocketHandler,
+  getQuery,
+  getRouterParam,
+  H3,
+  redirect,
+  serve,
+  serveStatic,
+  setResponseStatus,
+} from 'h3'
+import launch from 'launch-editor'
+import { createScanMeta } from './data'
+import { useLogger } from './logger'
+import { useUnlighthouse } from './unlighthouse'
+
+// Helper function to get MIME type based on file extension
+function getMimeType(filePath: string): string {
+  const ext = extname(filePath).toLowerCase()
+  const mimeTypes: Record<string, string> = {
+    '.js': 'application/javascript',
+    '.mjs': 'application/javascript',
+    '.css': 'text/css',
+    '.html': 'text/html',
+    '.json': 'application/json',
+    '.png': 'image/png',
+    '.jpg': 'image/jpeg',
+    '.jpeg': 'image/jpeg',
+    '.gif': 'image/gif',
+    '.svg': 'image/svg+xml',
+    '.ico': 'image/x-icon',
+    '.woff': 'font/woff',
+    '.woff2': 'font/woff2',
+    '.ttf': 'font/ttf',
+    '.eot': 'application/vnd.ms-fontobject',
+  }
+  return mimeTypes[ext] || 'application/octet-stream'
+}
+
+// WebSocket broadcasting service
+class WebSocketService {
+  private peers: Set<Peer> = new Set()
+
+  addPeer(peer: Peer) {
+    this.peers.add(peer)
+  }
+
+  removePeer(peer: Peer) {
+    this.peers.delete(peer)
+  }
+
+  broadcast(data: Record<string, any>) {
+    const jsonData = JSON.stringify(data)
+
+    for (const peer of this.peers) {
+      try {
+        peer.send(jsonData)
+      }
+      catch {
+        // Remove peer if it's no longer valid
+        this.peers.delete(peer)
+      }
+    }
+  }
+}
+
+// Global WebSocket service instance
+const wsService = new WebSocketService()
+
+/**
+ * Create broadcasting events that hook into the unlighthouse lifecycle
+ */
+export function createBroadcastingEvents() {
+  const { hooks } = useUnlighthouse()
+
+  hooks.hook('task-started', (path, response) => {
+    if (response.tasks.inspectHtmlTask === 'completed')
+      wsService.broadcast({ response })
+  })
+  hooks.hook('task-complete', (path, response) => {
+    if (response.tasks.inspectHtmlTask === 'completed')
+      wsService.broadcast({ response })
+  })
+  hooks.hook('task-added', (path, response) => {
+    if (response.tasks.inspectHtmlTask === 'completed')
+      wsService.broadcast({ response })
+  })
+}
+
+/**
+ * Create the complete H3 app with all routes and WebSocket support
+ */
+export function createH3App(): H3 {
+  const logger = useLogger()
+  const { resolvedConfig, runtimeSettings, hooks } = useUnlighthouse()
+
+  const app = new H3()
+
+  // Helper function to get report by ID
+  const useReport = (event: any) => {
+    const { worker } = useUnlighthouse()
+    const id = getRouterParam(event, 'id')
+    return id ? worker.findReport(id) : undefined
+  }
+
+  // Handle typos - redirect /__lighthouse/ to routerPrefix
+  app.get('/__lighthouse/**', async (event) => {
+    return redirect(event, resolvedConfig.routerPrefix)
+  })
+
+  // API Routes
+  app.post('/api/reports/rescan', async (event) => {
+    await hooks.callHook('visited-client')
+
+    const { worker } = useUnlighthouse()
+    const reports = [...worker.routeReports.values()]
+    logger.info(`Doing site rescan, clearing ${reports.length} reports.`)
+    worker.routeReports.clear()
+    reports.forEach((route) => {
+      const dir = route.artifactPath
+      if (fs.existsSync(dir))
+        fs.rmSync(dir, { recursive: true })
+    })
+    worker.queueRoutes(reports.map(report => report.route))
+    return true
+  })
+
+  app.post('/api/reports/:id/rescan', async (event) => {
+    await hooks.callHook('visited-client')
+
+    const report = useReport(event)
+    const { worker } = useUnlighthouse()
+
+    if (report)
+      worker.requeueReport(report, true) // true indicates manual rescan
+
+    return { success: true }
+  })
+
+  app.get('/api/__launch', async (event) => {
+    await hooks.callHook('visited-client')
+
+    const query = getQuery(event)
+    const file = query.file as string
+
+    if (!file) {
+      setResponseStatus(event, 400)
+      return false
+    }
+
+    const path = file.replace(resolvedConfig.root, '')
+    const resolved = join(resolvedConfig.root, path)
+    logger.info(`Launching file in editor: \`${path}\``)
+    launch(resolved)
+
+    return { success: true }
+  })
+
+  // WebSocket route using h3 v2 defineWebSocketHandler
+  app.get('/api/ws', defineWebSocketHandler({
+    async upgrade(request) {
+      await hooks.callHook('visited-client')
+    },
+
+    async open(peer) {
+      wsService.addPeer(peer)
+    },
+
+    message(peer, message) {
+      // Handle incoming WebSocket messages if needed
+    },
+
+    close(peer, event) {
+      wsService.removePeer(peer)
+    },
+
+    error(peer, error) {
+      logger.error('WebSocket error:', error)
+    },
+  }))
+
+  app.get('/api/reports', async (event) => {
+    await hooks.callHook('visited-client')
+
+    const { worker } = useUnlighthouse()
+    return worker.reports().filter(r => r.tasks.inspectHtmlTask === 'completed')
+  })
+
+  app.get('/api/scan-meta', async (event) => {
+    await hooks.callHook('visited-client')
+    return createScanMeta()
+  })
+
+  // Serve static files from the generated client path
+  app.get('/**', async (event) => {
+    await hooks.callHook('visited-client')
+    return serveStatic(event, {
+      getContents: (id) => {
+        let filePath = join(runtimeSettings.generatedClientPath, id)
+
+        // If path is empty or ends with /, try index.html
+        if (!id || id.endsWith('/')) {
+          filePath = join(runtimeSettings.generatedClientPath, id || '', 'index.html')
+        }
+
+        // Check if it's a directory and try index.html
+        if (fs.existsSync(filePath) && fs.statSync(filePath).isDirectory()) {
+          filePath = join(filePath, 'index.html')
+        }
+
+        // Only read if it's a file
+        if (fs.existsSync(filePath) && fs.statSync(filePath).isFile()) {
+          return fs.readFileSync(filePath)
+        }
+
+        throw new Error('File not found')
+      },
+      getMeta: (id) => {
+        let filePath = join(runtimeSettings.generatedClientPath, id)
+
+        // If path is empty or ends with /, try index.html
+        if (!id || id.endsWith('/')) {
+          filePath = join(runtimeSettings.generatedClientPath, id || '', 'index.html')
+        }
+
+        // Check if it's a directory and try index.html
+        if (fs.existsSync(filePath) && fs.statSync(filePath).isDirectory()) {
+          filePath = join(filePath, 'index.html')
+        }
+
+        if (fs.existsSync(filePath) && fs.statSync(filePath).isFile()) {
+          const stats = fs.statSync(filePath)
+          return {
+            size: stats.size,
+            mtime: stats.mtime,
+            type: getMimeType(filePath),
+          }
+        }
+        return undefined
+      },
+    })
+  })
+
+  return app
+}
+
+/**
+ * Create and start the H3 server with WebSocket support
+ */
+export async function createH3Server() {
+  const { resolvedConfig } = useUnlighthouse()
+
+  const app = createH3App()
+
+  const server = await serve(app, {
+    open: false,
+    port: 3000,
+    ...resolvedConfig.server,
+    plugins: [
+      wsPlugin({
+        resolve: async req => (await app.fetch(req)).crossws,
+      }),
+    ],
+  })
+
+  return { app, server }
+}
