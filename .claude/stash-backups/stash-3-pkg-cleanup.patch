@@ -0,0 +1,42 @@
+import type { NormalisedRoute } from '@unlighthouse/core'
+import type { UseFetchReturn } from '@vueuse/core'
+import type { Ref } from 'vue'
+import { useFetch } from '../fetch'
+
+export const rescanRouteRequests: Ref<Map<string, UseFetchReturn<any>>> = ref(new Map())
+export const rescanningRoutes: Ref<Set<string>> = ref(new Set())
+
+export function rescanRoute(route: NormalisedRoute, done?: () => void) {
+  const fetch = useFetch(`/reports/${route.id}/rescan`).post()
+  rescanRouteRequests.value.set(route.id, fetch)
+
+  fetch.onFetchResponse(() => {
+    rescanRouteRequests.value.delete(route.id)
+    // Keep the route in rescanning state until the report is updated
+    rescanningRoutes.value.add(route.id)
+    done?.()
+  })
+
+  fetch.onFetchError(() => {
+    rescanRouteRequests.value.delete(route.id)
+    rescanningRoutes.value.delete(route.id)
+  })
+
+  return fetch
+}
+
+export function isRescanRouteRequestRunning(routeId: string) {
+  return computed(() => {
+    return rescanRouteRequests.value.get(routeId)?.isFetching || false
+  })
+}
+
+export function isRouteRescanning(routeId: string) {
+  return computed(() => {
+    return rescanningRoutes.value.has(routeId)
+  })
+}
+
+export function markRouteRescanComplete(routeId: string) {
+  rescanningRoutes.value.delete(routeId)
+}
