{
  "name": "@unlighthouse/monorepo",
  "type": "module",
  "version": "0.17.4",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "license": "MIT",
  "scripts": {
    "cli": "node packages/unlighthouse/dist/cli/cli.mjs",
    "ci": "node packages/unlighthouse/dist/cli/ci.mjs",
    "ci:docs": "node packages/unlighthouse/dist/cli/ci.mjs --site unlighthouse.dev --build-static --debug",
    "build": "pnpm run build:pkg",
    "build:docs": "cd docs && pnpm i && nuxi build",
    "build:pkg": "pnpm -r --filter './packages/**' run build",
    "stub": "pnpm -r --parallel run stub",
    "lint": "eslint . --fix",
    "typecheck": "pnpm -r --filter './packages/**' --if-present run typecheck",
    "bump": "bumpp package.json packages-aliased/*/package.json packages/*/package.json --commit --push --tag",
    "release": "pnpm build && pnpm bump",
    "test": "vitest",
    "test:update": "vitest -u",
    "docs": "npm -C docs run dev",
    "docs:build": "npm -C docs run build",
    "docs:serve": "npm -C docs run serve",
    "test:attw": "pnpm -r --filter './packages/**' --if-present run test:attw",
    "test:publint": "pnpm -r --filter './packages/**' --if-present run test:publint",
    "lint:docs": "pnpx markdownlint-cli ./docs && pnpx case-police 'docs/**/*.md' *.md",
    "lint:docs:fix": "pnpx markdownlint-cli ./docs --fix && pnpx case-police 'docs/**/*.md' *.md --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@arethetypeswrong/cli": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "better-sqlite3": "catalog:dependencies",
    "bumpp": "catalog:",
    "drizzle-orm": "catalog:dependencies",
    "eslint": "catalog:",
    "fs-extra": "catalog:dependencies",
    "h3": "catalog:dependencies",
    "jiti": "catalog:",
    "obuild": "catalog:",
    "publint": "catalog:",
    "rolldown": "catalog:",
    "tinyexec": "catalog:dependencies",
    "typescript": "catalog:",
    "vite": "catalog:dependencies",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
