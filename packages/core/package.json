{
  "name": "@unlighthouse/core",
  "type": "module",
  "version": "0.0.0-v1",
  "private": true,
  "description": "Pure core modules for Unlighthouse v1 (report, comparison, seeds, policies, crawlers, auditors, storage, api).",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./report": {
      "types": "./dist/report/index.d.mts",
      "import": "./dist/report/index.mjs"
    },
    "./comparison": {
      "types": "./dist/comparison/index.d.mts",
      "import": "./dist/comparison/index.mjs"
    },
    "./seeds": {
      "types": "./dist/seeds/index.d.mts",
      "import": "./dist/seeds/index.mjs"
    },
    "./policies": {
      "types": "./dist/policies/index.d.mts",
      "import": "./dist/policies/index.mjs"
    },
    "./crawlers": {
      "types": "./dist/crawlers/index.d.mts",
      "import": "./dist/crawlers/index.mjs"
    },
    "./auditors": {
      "types": "./dist/auditors/index.d.mts",
      "import": "./dist/auditors/index.mjs"
    },
    "./util/path": {
      "types": "./dist/util/path.d.mts",
      "import": "./dist/util/path.mjs"
    },
    "./util/fetch": {
      "types": "./dist/util/fetch.d.mts",
      "import": "./dist/util/fetch.mjs"
    },
    "./util/filter": {
      "types": "./dist/util/filter.d.mts",
      "import": "./dist/util/filter.mjs"
    },
    "./util/progressBox": {
      "types": "./dist/util/progressBox.d.mts",
      "import": "./dist/util/progressBox.mjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.mts",
      "import": "./dist/storage/index.mjs"
    },
    "./storage/drizzle": {
      "types": "./dist/storage/drizzle/index.d.mts",
      "import": "./dist/storage/drizzle/index.mjs"
    },
    "./storage/memory": {
      "types": "./dist/storage/memory/index.d.mts",
      "import": "./dist/storage/memory/index.mjs"
    },
    "./storage/unstorage-blobs": {
      "types": "./dist/storage/unstorage-blobs/index.d.mts",
      "import": "./dist/storage/unstorage-blobs/index.mjs"
    },
    "./api": {
      "types": "./dist/api/index.d.mts",
      "import": "./dist/api/index.mjs"
    },
    "./api/client": {
      "types": "./dist/api/client.d.mts",
      "import": "./dist/api/client.mjs"
    },
    "./api/http": {
      "types": "./dist/api/http.d.mts",
      "import": "./dist/api/http.mjs"
    },
    "./api/handlers": {
      "types": "./dist/api/handlers/index.d.mts",
      "import": "./dist/api/handlers/index.mjs"
    },
    "./api/dashboard": {
      "types": "./dist/api/dashboard.d.mts",
      "import": "./dist/api/dashboard.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "dist/migrations/sqlite/**"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "obuild",
    "stub": "obuild --stub",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate"
  },
  "peerDependencies": {
    "better-sqlite3": "catalog:dependencies",
    "drizzle-orm": "catalog:dependencies",
    "unstorage": "catalog:"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "unstorage": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "catalog:dependencies",
    "@unlighthouse/audit-pool": "workspace:*",
    "@unlighthouse/contracts": "workspace:*",
    "axios": "catalog:dependencies",
    "chrome-launcher": "catalog:dependencies",
    "consola": "catalog:dependencies",
    "crawlee": "catalog:dependencies",
    "fs-extra": "catalog:dependencies",
    "h3": "catalog:dependencies",
    "hookable": "catalog:dependencies",
    "launch-editor": "catalog:dependencies",
    "lighthouse": "catalog:dependencies",
    "lodash-es": "catalog:dependencies",
    "mdream": "catalog:dependencies",
    "minimist": "catalog:dependencies",
    "ofetch": "catalog:dependencies",
    "pathe": "catalog:dependencies",
    "puppeteer-core": "catalog:dependencies",
    "radix3": "catalog:dependencies",
    "sanitize-filename": "catalog:dependencies",
    "sitemapper": "catalog:dependencies",
    "slugify": "catalog:dependencies",
    "ufo": "catalog:dependencies",
    "unctx": "catalog:dependencies",
    "ws": "catalog:dependencies"
  },
  "devDependencies": {
    "@types/better-sqlite3": "catalog:",
    "@types/fs-extra": "catalog:",
    "better-sqlite3": "catalog:dependencies",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:dependencies",
    "unstorage": "catalog:"
  }
}
