{
  "name": "@unlighthouse/audit-pool",
  "type": "module",
  "version": "0.0.0-v1",
  "private": true,
  "description": "Tinypool-backed Puppeteer worker pool optimized for Lighthouse audits.",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./worker": {
      "types": "./dist/worker.d.mts",
      "import": "./dist/worker.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "obuild",
    "stub": "obuild --stub",
    "typecheck": "tsc --noEmit",
    "test:attw": "attw --pack --profile esm-only",
    "test:publint": "publint"
  },
  "peerDependencies": {
    "puppeteer-core": "catalog:dependencies"
  },
  "dependencies": {
    "consola": "catalog:dependencies",
    "hookable": "catalog:dependencies",
    "tinypool": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "obuild": "catalog:",
    "puppeteer-core": "catalog:dependencies",
    "typescript": "catalog:"
  }
}
