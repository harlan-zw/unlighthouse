{
  "name": "@unlighthouse/cloudflare",
  "type": "module",
  "version": "0.0.0-v1",
  "private": true,
  "description": "Cloudflare Workers preset for Unlighthouse (populated in v5).",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "obuild",
    "stub": "obuild --stub",
    "typecheck": "tsc --noEmit",
    "test:attw": "attw --pack --profile esm-only",
    "test:publint": "publint"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "catalog:",
    "@unlighthouse/contracts": "workspace:*",
    "@unlighthouse/core": "workspace:*",
    "h3": "catalog:dependencies"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:"
  }
}
