{
  "name": "@unlighthouse/contracts",
  "type": "module",
  "version": "0.0.0-v1",
  "private": true,
  "description": "Shared types and contracts for Unlighthouse v1.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types/puppeteer": {
      "types": "./src/types/puppeteer.ts",
      "import": "./src/types/puppeteer.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "obuild",
    "stub": "obuild --stub",
    "typecheck": "tsc --noEmit"
  }
}
