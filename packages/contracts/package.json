{
  "name": "@unlighthouse/contracts",
  "type": "module",
  "version": "0.0.0-v1",
  "private": true,
  "description": "Shared types and contracts for Unlighthouse v1.",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./types/puppeteer": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./types/atoms": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./ports": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./drizzle": {
      "types": "./dist/drizzle/index.d.mts",
      "import": "./dist/drizzle/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "obuild",
    "stub": "obuild --stub",
    "typecheck": "tsc --noEmit",
    "test:attw": "attw --pack --profile esm-only",
    "test:publint": "publint"
  },
  "peerDependencies": {
    "drizzle-orm": "catalog:dependencies",
    "zod": "catalog:"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "dependencies": {
    "hookable": "catalog:dependencies"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "chrome-launcher": "catalog:dependencies",
    "lighthouse": "catalog:dependencies",
    "listhen": "catalog:dependencies",
    "puppeteer-core": "catalog:dependencies",
    "ufo": "catalog:dependencies",
    "zod": "catalog:"
  }
}
